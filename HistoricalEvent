public class HistoricalEvent {

    private String description;
    private Date eventDay;

    // Default constructor
    public HistoricalEvent() {
        description = "";
        eventDay = new Date();
    }

    // Full constructor
    public HistoricalEvent(String description, Date eventDay) {
        this.description = description;
        this.eventDay = new Date(eventDay); // deep copy
    }

    // Copy constructor
    public HistoricalEvent(HistoricalEvent original) {
        if (original != null) {
            this.description = original.description;
            this.eventDay = new Date(original.eventDay);
        }
    }

    // Getters
    public String getDescription() {
        return description;
    }

    public Date getEventDay() {
        return new Date(eventDay); // deep copy
    }

    // Setters
    public void setDescription(String description) {
        this.description = description;
    }

    public void setEventDay(Date eventDay) {
        this.eventDay = new Date(eventDay); // deep copy
    }

    // setAll method
    public void setAll(String description, Date eventDay) {
        this.description = description;
        this.eventDay = new Date(eventDay);
    }

    // toString
    @Override
    public String toString() {
        return "On " + eventDay + ": " + description;
    }

    // equals
    @Override
    public boolean equals(Object other) {

        if (other == null || !(other instanceof HistoricalEvent))
            return false;

        HistoricalEvent otherEvent = (HistoricalEvent) other;

        return description.equals(otherEvent.description)
                && eventDay.equals(otherEvent.eventDay);
    }
}